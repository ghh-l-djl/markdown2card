  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^20.11.30",
    "@typescript-eslint/parser": "^8.35.1",
    "esbuild": "^0.20.2",
    "eslint": "^9.39.1",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "obsidian": "^1.5.12",
    "tsx": "^4.23.0",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.35.1"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "html-to-image": "^1.11.11"
  }
}
