{
  "name": "markdown2card",
  "version": "1.1.4",
  "description": "Obsidian plugin for rendering Markdown notes as card images.",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "build:local": "node esbuild.config.mjs local",
    "dev": "node esbuild.config.mjs",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts"
  },
  "keywords": [
